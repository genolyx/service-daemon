# docker compose 가 읽는 변수 (프로젝트 루트에서 --env-file 로 지정)
# 사용: cp .env.compose.example .env.compose
#
# 호스트에서 채우기:
#   id -u        → HOST_UID
#   id -g        → HOST_GID
#   getent group docker | cut -d: -f3   → DOCKER_GID (docker 그룹 없으면 0 또는 생략 불가 시 compose에서 group_add 제거)

TZ=Asia/Seoul
APP_ENV=dev
ENV_FILE=.env.docker

# 컨테이너 내부 APP_PORT(기본 8000) → 호스트 HOST_PORT 로 노출
HOST_PORT=8003
APP_PORT=8000

HOST_UID=1000
HOST_GID=1000
# compose 의 group_add: 호스트 /var/run/docker.sock 그룹과 반드시 일치 (보통: getent group docker | cut -d: -f3)
DOCKER_GID=988

# 데이터 / 파이프라인 (호스트 경로)
BASE_DIR=/data
# 주석 리소스: 호스트에 두고 compose 가 ${BASE_DIR}/reference:/data/reference:ro 로 마운트
# (ClinVar·gnomAD·genes 등 — .env.docker의 CLINVAR_VCF, GNOMAD_DIR 경로와 일치시킴)
# snpEff 유전체 DB는 /data/reference 가 ro 이면 쓰기용으로 SNPEFF_DATA_DIR(예: carrier_screening_work/snpeff) 사용

# Carrier 호스트 경로 → (1) 컨테이너 /data/carrier_screening (2) 동일 경로 HOST:HOST (run_analysis 의 docker -v 용)
# .env.docker 의 CARRIER_SCREENING_SCRIPT_DATA_DIR 이 여기와 동일해야 함
CARRIER_SCREENING_HOST=/home/ken/gx-exome
# sgNIPT 소스 코드 (run_sgnipt.sh 위치) — HOST:HOST :ro 마운트
SGNIPT_SRC_HOST=/home/ken/sgnipt
# sgNIPT 데이터 트리 (data/, config/, fastq/, analysis/ 등) — HOST:HOST 마운트
SGNIPT_LAYOUT_HOST=/home/ken/sgNIPT
# 주문 작업 트리(쓰기 가능). .env.docker 의 SGNIPT_WORK_ROOT=/data/sgnipt_work 와 호스트 경로 일치
SGNIPT_WORK_HOST=/data/sgnipt_work
CARRIER_SCREENING_PIPELINE_DIR=/home/ken/gx-exome
NIPT_PIPELINE_DIR=/opt/pipelines/nipt
SGNIPT_PIPELINE_DIR=/opt/pipelines/sgnipt

# docker-compose-dev.yml: snpEff 마운트 (프로젝트 tools/snpEff 에 snpEff.jar + snpEff.config 복사)
# SNPEFF_TOOLS_HOST=./tools/snpEff
# Nextflow는 Docker 이미지에 포함됨. 호스트 바이너리 마운트는 compose 주석 참고
