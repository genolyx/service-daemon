# ═══════════════════════════════════════════════════════════════
# Service Daemon - Docker/Production Configuration
# ═══════════════════════════════════════════════════════════════
# Docker 컨테이너 내부 경로 기준 설정.
# docker-compose.yml에서 볼륨 마운트와 함께 사용합니다.
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_NAME=service-daemon
APP_ENV=prod
APP_PORT=8000
LOG_LEVEL=INFO

# (선택) 외부 Portal/자동화 연동 시 — 설정하면 API 라우트에 Authorization: Bearer <값> 또는 X-API-Key 필요
# API_KEY=

# ─── Platform API ─────────────────────────────────────────────
PLATFORM_API_BASE=https://api.genolyx.com
AUTH_URL=https://api.genolyx.com/auth/login
# false 이면 로그인/상태/업로드 등 Genolyx 호출 생략 (로컬·포털만)
PLATFORM_API_ENABLED=false
# 연동 시 Genolyx 발급 계정 (changeme 는 401)
API_USERNAME=daemon-user
API_PASSWORD=changeme

# ─── Queue / Worker ───────────────────────────────────────────
MAX_CONCURRENT_JOBS=2
QUEUE_POLL_INTERVAL=30

# ─── Enabled Services ────────────────────────────────────────
ENABLED_SERVICES=carrier_screening,sgnipt

# ─── Base Directories (Docker 볼륨 마운트 경로) ───────────────
BASE_DIR=/data
FASTQ_BASE_DIR=/data/fastq
ANALYSIS_BASE_DIR=/data/analysis
OUTPUT_BASE_DIR=/data/output
LOG_BASE_DIR=/data/log

# 포털 FASTQ browse / PATCH 검증용 — 컨테이너 내부 경로
# compose: CARRIER_SCREENING_HOST 로 호스트 carrier_screening 전체 → /data/carrier_screening (rw).
# fastq 만 ro 마운트하면 analysis 형제 폴더 생성 시 Permission denied.
CARRIER_SCREENING_FASTQ_DIR=/data/carrier_screening/fastq
# 분석·로그·산출물만 이 경로 아래에 생성 (FASTQ 트리는 ro/타 UID 일 때 Permission denied 방지)
CARRIER_SCREENING_ARTIFACT_BASE=/data/carrier_screening_work
# sgNIPT: 주문 산출물은 SGNIPT_WORK_ROOT 아래 (데몬 UID 쓰기 가능). 미설정 시 LAYOUT_ROOT 사용 → root 소유면 Permission denied.
# 호스트: mkdir -p /data/sgnipt_work && sudo chown $HOST_UID:$HOST_GID /data/sgnipt_work (compose 의 SGNIPT_WORK_HOST 와 일치)
# SGNIPT_WORK_ROOT: daemon Job 경로 루트. run_sgnipt.sh 의 SGNIPT_ROOT_DIR 과 일치 권장.
# (SGNIPT_ROOT_DIR 와 다르면 prepare_inputs 경로와 스크립트 경로가 달라짐)
SGNIPT_WORK_ROOT=/home/ken/sgNIPT
# 참조용(문서/기본값). 실제 Job 경로는 SGNIPT_WORK_ROOT 우선.
SGNIPT_LAYOUT_ROOT=/home/ken/sgNIPT
# 비우면 SGNIPT_WORK_ROOT/fastq (읽기 전용 browse 만 쓰려면 SGNIPT_FASTQ_DIR 로 별도 지정)
# SGNIPT_FASTQ_DIR=/home/ken/sgNIPT/fastq
SGNIPT_DOCKER_IMAGE=sgnipt
SGNIPT_RUN_SCRIPT_PATH=/home/ken/sgnipt/src/run_sgnipt.sh
SGNIPT_CONTAINER_MOUNT_ROOT=/Work/SgNIPT
# run_sgnipt.sh 자체가 docker run을 수행하므로 데몬에서 이중으로 감싸지 않음 (carrier 패턴)
SGNIPT_USE_DOCKER=false
# run_sgnipt.sh 가 호스트 경로를 docker -v 로 넘기므로 HOST 경로 지정 (컨테이너 경로 아님)
SGNIPT_ROOT_DIR=/home/ken/sgNIPT
# SGNIPT_DOCKER_EXTRA_ARGS=-v /path/to/refs:/Work/SgNIPT/data
# 모든 서비스 FASTQ가 /data/fastq 아래만 쓸 때는 위 대신 둘 다 /data/fastq 로 통일해도 됨

# ─── Pipeline Directory ──────────────────────────────────────
CARRIER_SCREENING_PIPELINE_DIR=/opt/pipelines/carrier-screening
# main.nf 가 bin/ 이 아니면 컨테이너 내 절대 경로로 지정 (예: .../main.nf 또는 .../workflow/main.nf)
# CARRIER_SCREENING_MAIN_NF=/opt/pipelines/carrier-screening/main.nf

# run_analysis.sh: (1) RUN_SCRIPT (2) layout …/src (3) pipeline_dir
# CARRIER_SCREENING_RUN_SCRIPT=/data/carrier_screening/src/run_analysis.sh
# 내부 docker -v 는 호스트 경로여야 함 → .env.compose 의 CARRIER_SCREENING_HOST 와 같은 값을 -d 로 씀 (compose 가 HOST:HOST 마운트)
CARRIER_SCREENING_SCRIPT_DATA_DIR=/home/ken/carrier_screening
# CARRIER_SCREENING_SCRIPT_REF_DIR=/home/ken/carrier_screening/data/refs
# CARRIER_SCREENING_SCRIPT_EXTRA_ARGS=--skip-cnv

# ─── Nextflow ─────────────────────────────────────────────────
NEXTFLOW_EXECUTABLE=/usr/local/bin/nextflow

# ─── Reference Genome ────────────────────────────────────────
# 호스트: compose 의 ${BASE_DIR}/reference → 컨테이너 /data/reference (:ro 권장)
# 아래 파일들이 없으면 /health?annotation=true 에서 ok:false 로 표시됨.
REF_FASTA=/data/reference/hg38/Homo_sapiens_assembly38.fasta
REF_FAI=/data/reference/hg38/Homo_sapiens_assembly38.fasta.fai
REF_DICT=/data/reference/hg38/Homo_sapiens_assembly38.dict
REF_BWA_INDICES=/data/reference/hg38/bwa

# ─── Annotation Resources ────────────────────────────────────
# 대용량 파일: /data/reference/annotation/ 에 보관 (sdb1, 볼륨 마운트)
# 이동 원본: carrier_screening/Genomics_Pipeline/phenotype_portal/{clinvar,gnomad,MANE...}
CLINVAR_VCF=/data/reference/annotation/clinvar/clinvar.vcf.gz
GNOMAD_DIR=/data/reference/annotation/gnomad
# gnomAD genomes v3.1.2 (phenotype_portal에서 이동, 파일명: gnomad.genomes.v3.1.2.sites.chrN.vcf.bgz)
GNOMAD_GENOMES_GLOB=gnomad.genomes.v3.1.2.sites.*.vcf.bgz
# exomes 파일이 있으면 아래도 설정 (없으면 genomes만 사용)
GNOMAD_EXOMES_GLOB=gnomad.exomes.v*.sites.*.vcf.bgz
DBSNP_VCF=/data/reference/annotation/dbsnp/dbsnp_156.vcf.gz

# snpEff: JAR+config 는 tools/snpEff/ (이미지 또는 마운트). DB 이름은 snpEff.config 에 정의된 것만 가능.
# 예: GRCh38.86, hg38, GRCh38.p7.RefSeq — GRCh38.p13.RefSeq 는 구버전 배포본 config 에 없음.
# DB 다운로드: bash /app/scripts/snpeff-download.sh (또는 호스트 snpEff/data/GRCh38.86 를 SNPEFF_DATA_DIR 로 복사)
SNPEFF_JAR=/opt/tools/snpEff/snpEff.jar
SNPEFF_DB=GRCh38.86
SNPEFF_DATA_DIR=/data/carrier_screening_work/snpeff

# 이미지 내장 소형 참조 파일 (/app/data/ → Dockerfile COPY data/)
CLINGEN_TSV=/app/data/clingen/ClinGen_gene_curation_list_GRCh38.tsv
GENE_BED=/app/data/reference/genes_hg38.bed
HPO_GENE_FILE=/app/data/hpo/genes_to_phenotype.txt
DISEASE_GENE_JSON=/app/data/db/disease_gene_mapping.json
KNOWN_CARRIER_GENES=/app/data/reference/known_gene_list.txt

# MANE: phenotype_portal에서 이동 (.gff, 비압축)
MANE_GFF=/data/reference/annotation/mane/MANE.GRCh38.v1.3.ensembl_genomic.gff
CURATED_VARIANTS_DB=/data/reference/annotation/curated/curated_variants.sqlite
# HGMD_VCF=/data/reference/annotation/hgmd/HGMD_Pro_2024.4_hg38.vcf.gz

# ─── Carrier Screening Specific ──────────────────────────────
# BED: 이미지 내장 소형 파일 사용 가능, 대형 Twist BED는 볼륨 마운트
# ACMG 2021 Tier 3 Expanded Carrier Screening - 113 genes, 14.2 Mb (GRCh38)
# 출처: Gregg et al., Genetics in Medicine 2021 (PMC8488021)
CARRIER_DEFAULT_BACKBONE_BED=/app/data/bed/Carrier_ACMG2021.bed
# 이전 테스트 BED (NIPT CNV 영역 320 regions, 1167 Mb - 너무 광범위):
# CARRIER_DEFAULT_BACKBONE_BED=/app/data/bed/Carrier_test.bed
# CARRIER_DEFAULT_DISEASE_BED=   # disease-specific BED 없으면 backbone과 동일하게 처리
#
# 실제 캐리어 스크리닝용 (호스트 볼륨 마운트 필요):
# CARRIER_DEFAULT_BACKBONE_BED=/data/bed/carrier_panel.bed   # 예: Twist Carrier Expanded Panel
# CARRIER_DEFAULT_DISEASE_BED=/data/bed/carrier_panel.bed

# ─── Report Generation ───────────────────────────────────────
# 템플릿은 이미지 내장 (/app/data/templates/)
REPORT_TEMPLATE_DIR=/app/data/templates
REPORT_LANGUAGES=EN,CN,KO
# REPORT_LOGO_PATH=/app/data/assets/genolyx_logo.png

# ─── AI Classification ───────────────────────────────────────
ACMG_AI_ENABLED=true
# AI 제공자: gemini | openai (기본값: gemini)
ACMG_AI_PROVIDER=gemini
ACMG_AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=AIzaSyBqcFTJ3q8juGkCcra5C_-WASmLgE617Nw
# ACMG_AI_API_KEY=sk-...   # OpenAI 사용 시 OpenAI API 키

# ─── Literature Search (PubMed) ──────────────────────────────
LITERATURE_ENABLED=true
LITERATURE_MAX_RESULTS=20
NCBI_EMAIL=ezscienceplan@gmail.com
NCBI_API_KEY=2ad37e448a9c63c0dd29b879fb5ad3fb1309
