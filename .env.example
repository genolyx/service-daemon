# ═══════════════════════════════════════════════════════════════
# Service Daemon Configuration (.env)
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your environment.
# All paths should be absolute paths on the host machine.
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_NAME=service-daemon
APP_ENV=prod
APP_PORT=8000
LOG_LEVEL=INFO

# (선택) 인바운드 API 보호 — 설정 시 /order, /api, /queue 등에 Bearer 또는 X-API-Key 필요 (/health, /portal, /static 제외)
# API_KEY=

# ─── Platform API ─────────────────────────────────────────────
PLATFORM_API_BASE=https://api.genolyx.com
AUTH_URL=https://api.genolyx.com/auth/login
API_USERNAME=daemon-user
API_PASSWORD=your-secure-password

# ─── Telegram (optional) ────────────────────────────────────
# BotFather 토큰 + 수신 chat ID(숫자). 쉼표로 여러 개 가능. 비우면 알림 비활성.
# TELEGRAM_BOT_TOKEN=AAFUir07cKdcC04NmvKMIRgQM55Pn9xEqhQ
# TELEGRAM_CHAT_IDS=@Genolyx_bot
# TELEGRAM_NOTIFY_ENABLED=true

# ─── Queue / Worker ───────────────────────────────────────────
MAX_CONCURRENT_JOBS=2
QUEUE_POLL_INTERVAL=30

# ─── Enabled Services ────────────────────────────────────────
# Comma-separated list of services to enable
ENABLED_SERVICES=carrier_screening,whole_exome,sgnipt

# ─── Base Directories ────────────────────────────────────────
# carrier_screening 서비스의 디렉토리 구조 (호스트: /home/ken/gx-exome):
#   gx-exome/fastq/<work_dir>/<sample_name>/
#   gx-exome/analysis/<work_dir>/<sample_name>/
#   gx-exome/output/<work_dir>/<sample_name>/
#   gx-exome/log/<work_dir>/<sample_name>/
BASE_DIR=/data
FASTQ_BASE_DIR=/data/fastq
ANALYSIS_BASE_DIR=/data/analysis
OUTPUT_BASE_DIR=/data/output
LOG_BASE_DIR=/data/log

# ─── Service-specific Pipeline Directories ────────────────────
CARRIER_SCREENING_PIPELINE_DIR=/home/ken/gx-exome
# Unified dark-gene Nextflow (single workflow: FASTQ→align→dark genes).
# Set CARRIER_SCREENING_FORCE_DIRECT_NEXTFLOW=true so the daemon does not auto-pick run_analysis.sh
# (otherwise src/run_analysis.sh under the carrier repo wins and DARK_GENE_PIPELINE_DIR is ignored).
# Example: DARK_GENE_PIPELINE_DIR=/home/ken/dark_gene_pipeline
# CARRIER_SCREENING_FORCE_DIRECT_NEXTFLOW=true
# DARK_GENE_SKIP_CNV=true
# CARRIER_SCREENING_NEXTFLOW_PROFILE=docker
# Optional explicit entry: CARRIER_SCREENING_MAIN_NF=/home/ken/dark_gene_pipeline/main.nf
# Optional: run_analysis.sh instead of direct nextflow (see .env.docker comments)
# CARRIER_SCREENING_RUN_SCRIPT=/home/ken/gx-exome/src/run_analysis.sh
# CARRIER_SCREENING_SCRIPT_DATA_DIR=/home/ken/gx-exome
# CARRIER_SCREENING_SCRIPT_REF_DIR=/home/ken/gx-exome/data/refs
# CARRIER_SCREENING_SCRIPT_EXTRA_ARGS=  # --work-dir/--sample/--data-dir/--panel/--aligner/--variant-caller/--no-skip-vep/--skip-cnv 는 daemon 이 자동으로 포함함. 추가 옵션만 여기에 설정 (예: --shared-ref-dir /path).
# Portal "Generate Report" (Review tab): write report.json + PDFs under
#   <root>/output/<work_dir>/<sample_name>/ and QC from <root>/analysis/...
# Example (Sam's host):
# CARRIER_SCREENING_REPORT_OUTPUT_ROOT=/home/sam/Carrier_result
# Jinja PDF templates (carrier_EN.html, carrier_couples_EN.html, …). Default: data/carrier_report
# in the image / repo (same layout as Carrier_result/carrier_report). Override:
# CARRIER_SCREENING_REPORT_TEMPLATE_DIR=/home/sam/Carrier_result/carrier_report
# To refresh repo copies from your Carrier_result folder: ./scripts/sync_carrier_report_templates.sh /path/to/carrier_report
NIPT_PIPELINE_DIR=/opt/pipelines/nipt
SGNIPT_PIPELINE_DIR=/opt/pipelines/sgnipt
# sgNIPT (Docker 권장: carrier 와 동일 — WORK_ROOT·ROOT_DIR 를 BASE_DIR/sgnipt_work 등 쓰기 전용으로 통일, FASTQ browse 만 레이아웃)
# SGNIPT_WORK_ROOT=/data/sgnipt_work
# SGNIPT_ROOT_DIR=/data/sgnipt_work
SGNIPT_LAYOUT_ROOT=/home/ken/sgNIPT
# SGNIPT_FASTQ_DIR=/home/ken/sgNIPT/fastq
# 소스 클론이 LAYOUT 와 다를 때(예: /home/ken/sgnipt); 비우면 RUN_SCRIPT_PATH·WORK·LAYOUT 만 시도
# SGNIPT_SRC_ROOT=/home/ken/sgnipt
SGNIPT_DOCKER_IMAGE=sgnipt
SGNIPT_RUN_SCRIPT_PATH=/home/ken/sgnipt/src/run_sgnipt.sh
SGNIPT_CONTAINER_MOUNT_ROOT=/Work/SgNIPT
SGNIPT_USE_DOCKER=true

# ─── Nextflow ─────────────────────────────────────────────────
NEXTFLOW_EXECUTABLE=nextflow
NEXTFLOW_CONFIG=/opt/pipelines/nextflow.config

# ═══════════════════════════════════════════════════════════════
# Reference Genome
# ═══════════════════════════════════════════════════════════════
REF_FASTA=/data/reference/hg38/Homo_sapiens_assembly38.fasta
REF_FAI=/data/reference/hg38/Homo_sapiens_assembly38.fasta.fai
REF_DICT=/data/reference/hg38/Homo_sapiens_assembly38.dict
REF_BWA_INDICES=/data/reference/hg38/bwa

# ═══════════════════════════════════════════════════════════════
# Annotation Resources
# ═══════════════════════════════════════════════════════════════

# ─── ClinVar ──────────────────────────────────────────────────
# Download: https://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh38/
CLINVAR_VCF=/data/reference/annotation/clinvar/clinvar_20250101.vcf.gz

# ─── gnomAD ───────────────────────────────────────────────────
# gnomAD v4.1 exomes recommended for carrier screening
# Download: https://gnomad.broadinstitute.org/downloads
GNOMAD_VCF=/data/reference/annotation/gnomad/gnomad.exomes.v4.1.sites.vcf.bgz
GNOMAD_DIR=/data/reference/annotation/gnomad
GNOMAD_GENOMES_GLOB=gnomad.genomes.v4.1.sites.*.vcf.bgz
GNOMAD_EXOMES_GLOB=gnomad.exomes.v4.1.sites.*.vcf.bgz

# ─── dbSNP ────────────────────────────────────────────────────
# Download: https://ftp.ncbi.nih.gov/snp/latest_release/VCF/
DBSNP_VCF=/data/reference/annotation/dbsnp/dbsnp_156.vcf.gz

# ─── snpEff ───────────────────────────────────────────────────
# JAR: 이미지 내장 (tools/snpEff/snpEff.jar → /opt/tools/snpEff/snpEff.jar)
# 빌드 전: cp /path/to/snpEff.jar tools/snpEff/
# DB: 최초 1회 다운로드: docker compose exec service-daemon bash /app/scripts/snpeff-download.sh
SNPEFF_JAR=/opt/tools/snpEff/snpEff.jar
# snpEff.config 에 있는 이름만 사용 (예: GRCh38.86). 최신 snpEff로 p13.RefSeq 사용 가능.
SNPEFF_DB=GRCh38.86
SNPEFF_DATA_DIR=/data/carrier_screening_work/snpeff

# ─── ClinGen ──────────────────────────────────────────────────
# 이미지 내장 (data/clingen/ → /app/data/clingen/)
CLINGEN_TSV=/app/data/clingen/ClinGen_gene_curation_list_GRCh38.tsv

# ─── MANE RefSeq ──────────────────────────────────────────────
# 대용량: 볼륨 마운트 필요
# Download: https://ftp.ncbi.nlm.nih.gov/refseq/MANE/MANE_human/current/
MANE_GFF=/data/reference/annotation/mane/MANE.GRCh38.v1.3.refseq_genomic.gff.gz

# ─── Gene Coordinates ─────────────────────────────────────────
# 이미지 내장 (data/reference/genes_hg38.bed → /app/data/reference/genes_hg38.bed)
GENE_BED=/app/data/reference/genes_hg38.bed

# ─── Portal: WES / exome panel packages (Panels tab) ─────────
# In Docker, /app is often read-only — do not use default data/wes_panels_custom.json under /app.
# Point these at a writable volume (e.g. BASE_DIR=/data in docker-compose).
# WES_PANELS_CUSTOM_JSON=/data/wes_panels/wes_panels_custom.json
# WES_PANELS_GENERATED_DIR=/data/wes_panels/generated
# Optional default for “build subset BED from gene list”: same column-4 gene BED as GENE_BED or Twist capture
# WES_PANEL_GENE_SOURCE_BED=/data/reference/twist_exome_hg38.bed

# ═══════════════════════════════════════════════════════════════
# Carrier Screening Specific Resources
# ═══════════════════════════════════════════════════════════════

# ─── HPO (Human Phenotype Ontology) ──────────────────────────
# 이미지 내장 (data/hpo/ → /app/data/hpo/)
HPO_GENE_FILE=/app/data/hpo/genes_to_phenotype.txt

# ─── Curated Variant Database ─────────────────────────────────
# 볼륨 마운트 (기관별 curated 변이 DB)
CURATED_VARIANTS_DB=/data/reference/annotation/curated/curated_variants.sqlite

# ─── Disease & Gene Lists ─────────────────────────────────────
# 이미지 내장 (data/db/, data/reference/ → /app/data/)
DISEASE_GENE_JSON=/app/data/db/disease_gene_mapping.json
KNOWN_CARRIER_GENES=/app/data/reference/known_gene_list.txt

# ─── HGMD (Human Gene Mutation Database) ──────────────────────
# Requires license from QIAGEN
# HGMD_VCF=/data/reference/annotation/hgmd/HGMD_Pro_2024.4_hg38.vcf.gz

# ═══════════════════════════════════════════════════════════════
# Report Generation
# ═══════════════════════════════════════════════════════════════
# 이미지 내장 (data/carrier_report/ → /app/data/carrier_report/)
REPORT_TEMPLATE_DIR=/app/data/carrier_report
REPORT_LANGUAGES=EN,CN,KO
# REPORT_LOGO_PATH=/app/data/assets/genolyx_logo.png

# ─── AI Classification (Optional) ────────────────────────────
ACMG_AI_ENABLED=false
ACMG_AI_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=sk-...

# ─── Gemini + gene_knowledge (portal Review Case / Gene database) ─
# Do not commit real keys; copy this file to .env (gitignored) and set there.
# Docker (docker-compose*.yml): .env is merged after .env.docker; put GEMINI_API_KEY in .env so it overrides tracked defaults.
# If Google returns API_KEY_INVALID: key deleted/revoked, typo, or GCP key restricted to HTTP referrers (breaks server-side); use AI Studio key or relax restrictions.
# If GEMINI_API_KEY is unset, Settings may load it from:
#   GEMINI_API_KEY_ENV_FILE (default: /home/sam/genetic_reporter_lookup/.env)
# If GENE_KNOWLEDGE_DB is unset and that directory exists, Settings may default to:
#   genetic_reporter_lookup's genetic_knowledge.db (see gene_knowledge_db_fallback_path in app/config.py)
# GEMINI_API_KEY=
# GENE_KNOWLEDGE_DB=/home/sam/genetic_reporter_lookup/genetic_knowledge.db
# GENE_KNOWLEDGE_GEMINI_MODEL=gemini-2.5-flash
