# ═══════════════════════════════════════════════════════════════
# Service Daemon Configuration (.env)
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your environment.
# All paths should be absolute paths on the host machine.
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_NAME=service-daemon
APP_ENV=prod
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Platform API ─────────────────────────────────────────────
PLATFORM_API_BASE=https://api.genolyx.com
AUTH_URL=https://api.genolyx.com/auth/login
API_USERNAME=daemon-user
API_PASSWORD=your-secure-password

# ─── Queue / Worker ───────────────────────────────────────────
MAX_CONCURRENT_JOBS=2
QUEUE_POLL_INTERVAL=30

# ─── Enabled Services ────────────────────────────────────────
# Comma-separated list of services to enable
ENABLED_SERVICES=carrier_screening

# ─── Base Directories ────────────────────────────────────────
# carrier-screening 서비스의 디렉토리 구조:
#   carrier-screening/fastq/<work_dir>/<sample_name>/
#   carrier-screening/analysis/<work_dir>/<sample_name>/
#   carrier-screening/output/<work_dir>/<sample_name>/
#   carrier-screening/log/<work_dir>/<sample_name>/
BASE_DIR=/data
FASTQ_BASE_DIR=/data/fastq
ANALYSIS_BASE_DIR=/data/analysis
OUTPUT_BASE_DIR=/data/output
LOG_BASE_DIR=/data/log

# ─── Service-specific Pipeline Directories ────────────────────
CARRIER_SCREENING_PIPELINE_DIR=/opt/pipelines/carrier-screening
NIPT_PIPELINE_DIR=/opt/pipelines/nipt
SGNIPT_PIPELINE_DIR=/opt/pipelines/sgnipt

# ─── Nextflow ─────────────────────────────────────────────────
NEXTFLOW_EXECUTABLE=nextflow
NEXTFLOW_CONFIG=/opt/pipelines/nextflow.config

# ═══════════════════════════════════════════════════════════════
# Reference Genome
# ═══════════════════════════════════════════════════════════════
REF_FASTA=/data/reference/hg38/Homo_sapiens_assembly38.fasta
REF_FAI=/data/reference/hg38/Homo_sapiens_assembly38.fasta.fai
REF_DICT=/data/reference/hg38/Homo_sapiens_assembly38.dict
REF_BWA_INDICES=/data/reference/hg38/bwa

# ═══════════════════════════════════════════════════════════════
# Annotation Resources
# ═══════════════════════════════════════════════════════════════

# ─── ClinVar ──────────────────────────────────────────────────
# Download: https://ftp.ncbi.nlm.nih.gov/pub/clinvar/vcf_GRCh38/
CLINVAR_VCF=/data/reference/annotation/clinvar/clinvar_20250101.vcf.gz

# ─── gnomAD ───────────────────────────────────────────────────
# gnomAD v4.1 exomes recommended for carrier screening
# Download: https://gnomad.broadinstitute.org/downloads
GNOMAD_VCF=/data/reference/annotation/gnomad/gnomad.exomes.v4.1.sites.vcf.bgz
GNOMAD_DIR=/data/reference/annotation/gnomad
GNOMAD_GENOMES_GLOB=gnomad.genomes.v4.1.sites.*.vcf.bgz
GNOMAD_EXOMES_GLOB=gnomad.exomes.v4.1.sites.*.vcf.bgz

# ─── dbSNP ────────────────────────────────────────────────────
# Download: https://ftp.ncbi.nih.gov/snp/latest_release/VCF/
DBSNP_VCF=/data/reference/annotation/dbsnp/dbsnp_156.vcf.gz

# ─── snpEff ───────────────────────────────────────────────────
# Download: https://pcingola.github.io/SnpEff/
SNPEFF_JAR=/opt/tools/snpEff/snpEff.jar
SNPEFF_DB=GRCh38.105

# ─── ClinGen ──────────────────────────────────────────────────
# Download: https://search.clinicalgenome.org/kb/downloads
CLINGEN_TSV=/data/reference/annotation/clingen/ClinGen_gene_curation_list_GRCh38.tsv

# ─── MANE RefSeq ──────────────────────────────────────────────
# Download: https://ftp.ncbi.nlm.nih.gov/refseq/MANE/MANE_human/current/
MANE_GFF=/data/reference/annotation/mane/MANE.GRCh38.v1.3.refseq_genomic.gff.gz

# ─── Gene Coordinates ─────────────────────────────────────────
GENE_BED=/data/reference/annotation/genes/genes_hg38.bed

# ═══════════════════════════════════════════════════════════════
# Carrier Screening Specific Resources
# ═══════════════════════════════════════════════════════════════

# ─── HPO (Human Phenotype Ontology) ──────────────────────────
# Download: https://hpo.jax.org/data/annotations
# Or run: data/download_hpo_data.sh
HPO_GENE_FILE=/data/reference/annotation/hpo/genes_to_phenotype.txt

# ─── Curated Variant Database ─────────────────────────────────
# Internal SQLite DB of previously reviewed/classified variants
CURATED_VARIANTS_DB=/data/reference/annotation/curated/curated_variants.sqlite

# ─── Disease Database ─────────────────────────────────────────
# disease_gene_mapping.json is included in data/db/
DISEASE_DB_DIR=/data/reference/annotation/disease
DISEASE_GENE_JSON=/opt/pipelines/carrier-screening/data/db/disease_gene_mapping.json

# ─── HGMD (Human Gene Mutation Database) ──────────────────────
# Requires license from QIAGEN
# HGMD_VCF=/data/reference/annotation/hgmd/HGMD_Pro_2024.4_hg38.vcf.gz

# ─── Known Gene Lists ────────────────────────────────────────
KNOWN_CARRIER_GENES=/opt/pipelines/carrier-screening/data/reference/known_gene_list.txt
ACMG_SF_GENES=/data/reference/annotation/acmg/acmg_sf_v3.2_genes.txt

# ═══════════════════════════════════════════════════════════════
# Report Generation
# ═══════════════════════════════════════════════════════════════
REPORT_TEMPLATE_DIR=/opt/pipelines/carrier-screening/data/templates
REPORT_LANGUAGES=EN,CN,KO
REPORT_LOGO_PATH=/opt/pipelines/carrier-screening/data/assets/genolyx_logo.png

# ─── AI Classification (Optional) ────────────────────────────
ACMG_AI_ENABLED=false
ACMG_AI_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=sk-...
