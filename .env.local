# ═══════════════════════════════════════════════════════════════
# Service Daemon - Local Development Configuration
# ═══════════════════════════════════════════════════════════════
# Mac Studio 로컬 개발 환경용 설정.
# 이 파일을 .env로 복사하여 사용합니다:
#   cp .env.local .env
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_NAME=service-daemon
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=DEBUG

# ─── Platform API (로컬 개발에서는 비활성) ────────────────────
PLATFORM_API_BASE=http://localhost:9000
# AUTH_URL=
# API_USERNAME=
# API_PASSWORD=

# ─── Queue / Worker ───────────────────────────────────────────
MAX_CONCURRENT_JOBS=1
QUEUE_POLL_INTERVAL=10

# ─── Enabled Services ────────────────────────────────────────
ENABLED_SERVICES=carrier_screening

# ─── Base Directories (Mac Studio 경로 예시) ──────────────────
# 실제 Mac Studio 경로에 맞게 수정하세요
BASE_DIR=/Users/yourname/data
FASTQ_BASE_DIR=/Users/yourname/data/fastq
ANALYSIS_BASE_DIR=/Users/yourname/data/analysis
OUTPUT_BASE_DIR=/Users/yourname/data/output
LOG_BASE_DIR=/Users/yourname/data/log

# ─── Pipeline Directory ──────────────────────────────────────
# carrier-screening 레포 클론 경로
CARRIER_SCREENING_PIPELINE_DIR=/Users/yourname/repos/carrier-screening

# ─── Nextflow ─────────────────────────────────────────────────
NEXTFLOW_EXECUTABLE=nextflow
# NEXTFLOW_CONFIG=

# ═══════════════════════════════════════════════════════════════
# Reference Genome (Mac Studio에 다운로드한 경로)
# ═══════════════════════════════════════════════════════════════
REF_FASTA=/Users/yourname/data/reference/hg38/Homo_sapiens_assembly38.fasta
REF_FAI=/Users/yourname/data/reference/hg38/Homo_sapiens_assembly38.fasta.fai
REF_DICT=/Users/yourname/data/reference/hg38/Homo_sapiens_assembly38.dict
REF_BWA_INDICES=/Users/yourname/data/reference/hg38/bwa

# ═══════════════════════════════════════════════════════════════
# Annotation Resources
# ═══════════════════════════════════════════════════════════════
CLINVAR_VCF=/Users/yourname/data/reference/annotation/clinvar/clinvar.vcf.gz
GNOMAD_VCF=/Users/yourname/data/reference/annotation/gnomad/gnomad.exomes.v4.1.sites.vcf.bgz
GNOMAD_DIR=/Users/yourname/data/reference/annotation/gnomad
DBSNP_VCF=/Users/yourname/data/reference/annotation/dbsnp/dbsnp_156.vcf.gz
SNPEFF_JAR=/opt/homebrew/Cellar/snpeff/5.2/libexec/snpEff.jar
SNPEFF_DB=GRCh38.105
CLINGEN_TSV=/Users/yourname/data/reference/annotation/clingen/ClinGen_gene_curation_list_GRCh38.tsv
MANE_GFF=/Users/yourname/data/reference/annotation/mane/MANE.GRCh38.v1.3.refseq_genomic.gff.gz
GENE_BED=/Users/yourname/data/reference/annotation/genes/genes_hg38.bed

# ═══════════════════════════════════════════════════════════════
# Carrier Screening Specific (service-daemon 내부 data 사용)
# ═══════════════════════════════════════════════════════════════

# HPO - 개발용 서브셋은 data/hpo/ 에 포함됨
# 프로덕션용 전체 파일은 data/download_hpo_data.sh 로 다운로드
HPO_GENE_FILE=data/hpo/genes_to_phenotype.txt

# Disease-Gene Mapping JSON (service-daemon 내부)
DISEASE_GENE_JSON=data/db/disease_gene_mapping.json

# Known Gene List (service-daemon 내부)
KNOWN_CARRIER_GENES=data/reference/known_gene_list.txt

# Curated Variant DB (없으면 건너뜀)
# CURATED_VARIANTS_DB=

# HGMD (라이선스 필요, 없으면 건너뜀)
# HGMD_VCF=

# ═══════════════════════════════════════════════════════════════
# Report Generation (service-daemon 내부 templates 사용)
# ═══════════════════════════════════════════════════════════════
REPORT_TEMPLATE_DIR=data/templates
REPORT_LANGUAGES=EN,CN,KO
# REPORT_LOGO_PATH=data/assets/genolyx_logo.png

# ─── AI Classification ───────────────────────────────────────
ACMG_AI_ENABLED=false
ACMG_AI_MODEL=gpt-4.1-mini
